# Vite dev server origin (used by CORS settings in backend examples)
VITE_APP_PUBLIC_PATH=/

# API base URL (point this to your running manager-api)
VITE_APP_API_BASE_URL=http://localhost:3000

# Router mode: 'frontend' or 'backend'
VITE_APP_ROUTER_MODE=frontend

# Default route (optional)
VITE_APP_DEFAULT_ROUTE=/workbench
VITE_APP_DEFAULT_ROUTE = /workbench
VITE_APP_PUBLIC_PATH = /
VITE_APP_API_BASE_URL = /api
VITE_APP_ROUTER_MODE = frontend
